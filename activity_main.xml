<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#f5f5f5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="مولّد أرقام عشوائية"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="أول رقم (0-9):"
        android:textSize="16sp"
        android:layout_marginTop="15dp" />
    <EditText
        android:id="@+id/firstDigitInput"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:inputType="number"
        android:hint="ادخل أول رقم"
        android:padding="10dp"
        android:background="#fff" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="آخر رقم (0-9):"
        android:textSize="16sp"
        android:layout_marginTop="15dp" />
    <EditText
        android:id="@+id/lastDigitInput"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:inputType="number"
        android:hint="ادخل آخر رقم"
        android:padding="10dp"
        android:background="#fff" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="الطول الكلي:"
        android:textSize="16sp"
        android:layout_marginTop="15dp" />
    <EditText
        android:id="@+id/lengthInput"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:inputType="number"
        android:hint="ادخل الطول"
        android:padding="10dp"
        android:background="#fff" />

    <Button
        android:id="@+id/generateButton"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="توليد الأرقام"
        android:textSize="18sp"
        android:layout_marginTop="20dp"
        android:background="#2196F3"
        android:textColor="#fff" />

    <TextView
        android:id="@+id/resultText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="20sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginTop="30dp"
        android:padding="15dp"
        android:background="#fff" />
</LinearLayout>
